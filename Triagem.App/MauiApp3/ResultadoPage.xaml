<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp3.ResultadoPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F5F7F6"
    Shell.NavBarIsVisible="False">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="18"
                             MaximumWidthRequest="700"
                             HorizontalOptions="Fill">

            <Image Source="logo.png" HeightRequest="70" HorizontalOptions="Center" Margin="0,10,0,0"/>

            <Label Text="Resultado da triagem"
                   FontSize="24" FontAttributes="Bold"
                   TextColor="#0F172A" HorizontalOptions="Center"/>

            <Label x:Name="TituloTriagem"
                   FontSize="15" TextColor="#6B7280" HorizontalOptions="Center"/>

            <!-- CARD DO RESULTADO -->
            <Border BackgroundColor="White" StrokeThickness="0" StrokeShape="RoundRectangle 20" Padding="25" Shadow="0,6,24,#00000025">
                <VerticalStackLayout Spacing="16">

                    <!-- círculo com pontuação -->
                    <Border x:Name="CirculoPontuacao"
                            BackgroundColor="#10B981"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 100"
                            HeightRequest="130" WidthRequest="130"
                            HorizontalOptions="Center">
                        <VerticalStackLayout HorizontalOptions="Center" VerticalOptions="Center" Spacing="0">
                            <Label x:Name="Pontuacao" Text="0" FontSize="40" FontAttributes="Bold"
                                   TextColor="White" HorizontalOptions="Center"/>
                            <Label x:Name="PontuacaoMaxima" Text="de 0 pontos" FontSize="12"
                                   TextColor="White" HorizontalOptions="Center"/>
                        </VerticalStackLayout>
                    </Border>

                    <Label x:Name="Classificacao" Text="—"
                           FontSize="24" FontAttributes="Bold"
                           TextColor="#10B981" HorizontalOptions="Center"/>

                    <Label x:Name="Recomendacao"
                           FontSize="15" TextColor="#374151"
                           HorizontalTextAlignment="Center"/>

                    <BoxView HeightRequest="1" Color="#E5E7EB"/>

                    <!-- dados da pessoa avaliada -->
                    <Grid ColumnDefinitions="*,*,*" RowDefinitions="Auto,Auto" RowSpacing="4">
                        <Label Text="Paciente" FontSize="12" TextColor="#6B7280" HorizontalOptions="Center"/>
                        <Label Grid.Row="1" x:Name="NomePaciente" FontAttributes="Bold" TextColor="#0F172A" HorizontalOptions="Center"/>

                        <Label Grid.Column="1" Text="Idade" FontSize="12" TextColor="#6B7280" HorizontalOptions="Center"/>
                        <Label Grid.Column="1" Grid.Row="1" x:Name="IdadePaciente" FontAttributes="Bold" TextColor="#0F172A" HorizontalOptions="Center"/>

                        <Label Grid.Column="2" Text="Data" FontSize="12" TextColor="#6B7280" HorizontalOptions="Center"/>
                        <Label Grid.Column="2" Grid.Row="1" x:Name="DataTriagem" FontAttributes="Bold" TextColor="#0F172A" HorizontalOptions="Center"/>
                    </Grid>

                </VerticalStackLayout>
            </Border>

            <Label Text="⚠️ Este resultado é uma orientação inicial e não substitui uma avaliação profissional."
                   FontSize="12" TextColor="#6B7280" HorizontalTextAlignment="Center"/>

            <!-- AÇÕES -->
            <Button Text="🔁 Aplicar esta triagem em outra pessoa"
                    Clicked="RepetirTriagem"
                    BackgroundColor="#10B981"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="12" HeightRequest="52"/>

            <Button Text="Ver histórico desta triagem"
                    Clicked="VerHistorico"
                    BackgroundColor="White"
                    BorderColor="#10B981" BorderWidth="1.5"
                    TextColor="#10B981"
                    CornerRadius="12" HeightRequest="48"/>

            <Button Text="Voltar para a home"
                    Clicked="VoltarHome"
                    BackgroundColor="Transparent"
                    TextColor="#374151"
                    CornerRadius="12" HeightRequest="44"/>

            <BoxView HeightRequest="20" Color="Transparent"/>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
