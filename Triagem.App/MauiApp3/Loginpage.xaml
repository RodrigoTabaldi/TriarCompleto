<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="MauiApp3.LoginPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    BackgroundColor="#F5F7F6">

    <Grid>

        <!-- FUNDO DECORATIVO -->
        <Image 
            Source="iconelogo.png"
            Opacity="0.08"
            Aspect="AspectFill"
            HorizontalOptions="Start"
            VerticalOptions="Center"
            HeightRequest="400"/>

        <!-- CONTEÚDO -->
        <ScrollView>
            <VerticalStackLayout 
                VerticalOptions="Center"
                Padding="20"
                Spacing="20">

                <!-- CARD -->
                <Border 
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 20"
                    Padding="25"
                    HorizontalOptions="Center"
                    MaximumWidthRequest="500"
                    WidthRequest="{OnPlatform Android=380, iOS=380, WinUI=500}"
                    Shadow="0,4,20,#00000020">

                    <VerticalStackLayout Spacing="20">

                        <!-- LOGO -->
                        <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                            <Image Source="logo.png" HeightRequest="120"/>
                            <Label></Label>
                                
                        </HorizontalStackLayout>

                        <!-- TEXTO -->
                        <Label 
                            Text="Bem-vindo(a) de volta!"
                            FontSize="20"
                            HorizontalOptions="Center"
                            TextColor="#111827"/>

                        <Label 
                            Text="Faça login para acessar sua conta"
                            FontSize="14"
                            HorizontalOptions="Center"
                            TextColor="#6B7280"/>

                        <!-- EMAIL -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Email" TextColor="#374151"/>
                            <Entry 
                                x:Name="Email"
                                Placeholder="Email"
                                TextColor="Black"
                                PlaceholderColor="#9CA3AF"/>
                        </VerticalStackLayout>

                        <!-- SENHA -->
                        <VerticalStackLayout Spacing="5">
                            <Label Text="Senha" TextColor="#374151"/>
                            <Entry 
                                x:Name="Senha"
                                Placeholder="Sua senha"
                                IsPassword="True"
                                TextColor="Black"
                                PlaceholderColor="#9CA3AF"/>
                        </VerticalStackLayout>

                        <!-- BOTÃO LOGIN -->
                        <Button 
                            Text="Entrar"
                            Clicked="Entrar"
                            BackgroundColor="#10B981"
                            TextColor="White"
                            CornerRadius="10"
                            HeightRequest="50"/>

                        <!-- DIVISOR -->
                        <Label 
                            Text="ou"
                            HorizontalOptions="Center"
                            TextColor="#9CA3AF"/>

                        <!-- CADASTRO -->
                        <Button 
                            Text="Cadastrar"
                            Clicked="IrCadastro"
                            BackgroundColor="Transparent"
                            BorderColor="#10B981"
                            BorderWidth="2"
                            TextColor="#10B981"
                            CornerRadius="10"
                            HeightRequest="50"/>

                    </VerticalStackLayout>

                </Border>

            </VerticalStackLayout>
        </ScrollView>

    </Grid>

</ContentPage>